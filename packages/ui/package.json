{
  "name": "@ez-kit/ui",
  "version": "0.0.0",
  "description": "UI-focused utility helpers for modern frontend projects.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "size": "size-limit",
    "clean": "rimraf dist coverage"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 KB"
    }
  ]
}
