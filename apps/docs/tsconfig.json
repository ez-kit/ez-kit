{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"allowJs": false,
		"jsx": "preserve",
		"incremental": true,
		"isolatedModules": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"types": ["node"],
		"noEmit": true,
		"esModuleInterop": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
