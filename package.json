{
	"name": "ez-kit",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"description": "Monorepo for ez-kit npm UI helper libraries.",
	"packageManager": "pnpm@10.18.0",
	"scripts": {
		"new:pkg": "turbo gen package",
		"build": "turbo run build",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"size": "turbo run size",
		"clean": "turbo run clean",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"docs:dev": "pnpm --filter @ez-kit/docs dev",
		"docs:build": "pnpm --filter @ez-kit/docs build",
		"docs:start": "pnpm --filter @ez-kit/docs start",
		"ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm size",
		"prepare": "husky"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@eslint/js": "^9.39.4",
		"@next/eslint-plugin-next": "^16.2.1",
		"@size-limit/preset-small-lib": "^11.2.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"size-limit": "^11.2.0",
		"tsup": "^8.5.1",
		"turbo": "^2.8.20",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vitest": "^3.2.4"
	}
}
