{
  "name": "ez-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for ez-kit npm UI helper libraries.",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "size": "turbo run size",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "docs:dev": "pnpm --filter @ez-kit/docs dev",
    "docs:build": "pnpm --filter @ez-kit/docs build",
    "docs:start": "pnpm --filter @ez-kit/docs start",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm size"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.30.0",
    "@size-limit/preset-small-lib": "^11.2.0",
    "rimraf": "^6.1.3",
    "size-limit": "^11.2.0",
    "tsup": "^8.5.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
